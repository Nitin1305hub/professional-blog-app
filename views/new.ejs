
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Create Post</title>

  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <nav class="navbar">
  <h1>DevBlog</h1>

  <% if (locals.user) { %>
    <a href="/logout" class="nav-btn">Logout</a>
  <% } else { %>
    <a href="/login" class="nav-btn">Login</a>
  <% } %>
</nav>

  <main class="form-container">

    <h2>Create New Blog Post</h2>

   <form action="/posts" method="POST" class="blog-form">

      <label>Title</label>
      <input type="text" name="title" placeholder="Enter blog title" required />

      <label>Author</label>
      <input type="text" name="author" placeholder="Enter author name" required />

      <label>Category</label>
     <input type="text" name="category" placeholder="Technology, Coding, AI..." required />
      <label>Content</label>

     <textarea name="content" rows="10" placeholder="Write your blog content..." required></textarea>
      <button type="submit">
        Publish Post
      </button>

    </form>

  </main>

</body>
</html>