
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>DevBlog</title>

  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="navbar">
  <h1>DevBlog</h1>

  <% if (locals.user) { %>
    <div class="nav-links">
      <a href="/" class="nav-btn">Home</a>
      <a href="/profile/<%= locals.user.id %>" class="nav-btn">Profile</a>
      <a href="/posts/new" class="nav-btn">Create Post</a>
      <a href="/logout" class="nav-btn">Logout</a>
    </div>
  <% } else { %>
    <div class="nav-links">
      <a href="/login" class="nav-btn">Login</a>
      <a href="/register" class="nav-btn">Register</a>
    </div>
  <% } %>
</nav>

<section class="hero">
  <h2>Welcome to DevBlog</h2>

  <p>
    A professional blog platform built with
    Node.js, Express, EJS and MongoDB.
  </p>
</section>

<main class="container">

  <form action="/" method="GET" class="search-form">

    <input
      type="text"
      name="search"
      placeholder="Search by title, author, content..."
      value="<%= typeof search !== 'undefined' ? search : '' %>"
    >

    <select name="category">
      <option value="All">All Categories</option>

      <option value="Technology" <%= category === "Technology" ? "selected" : "" %>>
        Technology
      </option>

      <option value="Web Development" <%= category === "Web Development" ? "selected" : "" %>>
        Web Development
      </option>

      <option value="Coding" <%= category === "Coding" ? "selected" : "" %>>
        Coding
      </option>

      <option value="AI" <%= category === "AI" ? "selected" : "" %>>
        AI
      </option>

      <option value="Education" <%= category === "Education" ? "selected" : "" %>>
        Education
      </option>
    </select>

    <button type="submit">
      Search
    </button>

    <a href="/" class="clear-btn">
      Clear
    </a>

  </form>

  <% if (posts.length === 0) { %>

    <div class="empty">
      <h3>No Blog Posts Found</h3>
      <p>Try another search or category.</p>
    </div>

  <% } else { %>

    <div class="posts-grid">

      <% posts.forEach(post => { %>

        <div class="post-card">

          <% if (post.imageUrl) { %>
            <img
              src="<%= post.imageUrl %>"
              alt="Post Image"
              class="card-image"
            >
          <% } %>

          <h3><%= post.title %></h3>

         <p>
  <strong>By:</strong>
  <% if (post.user) { %>
    <a href="/profile/<%= post.user %>" class="author-link">
      <%= post.author %>
    </a>
  <% } else { %>
    <%= post.author %>
  <% } %>
</p>

          <p><strong>Category:</strong> <%= post.category %></p>

          <p>
            <%= post.content.substring(0, 120) %>...
          </p>

          <a
            href="/posts/<%= post._id %>"
            class="read-more"
          >
            Read More
          </a>

        </div>

      <% }) %>

    </div>

  <% } %>

</main>

</body>
</html>